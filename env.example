# Copy this file to .env and fill in your keys.
# The .env file is loaded automatically by python-dotenv.
#
#   cp .env.example .env
#   (then edit .env with your real keys)

# ── Anthropic (required for AI report generation) ──────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── VirusTotal (required for Real-World Targets → VirusTotal tab) ───────────
# Free key at https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/min, 500/day
VIRUSTOTAL_API_KEY=your-virustotal-api-key-here

# ── HuggingFace (optional — increases free-tier rate limits) ────────────────
# Get a token at https://huggingface.co/settings/tokens
# Without this the HF tab still works but may hit rate limits faster
HF_TOKEN=
